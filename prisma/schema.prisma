generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Message {
  id        Int      @id @default(autoincrement())
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())
}
